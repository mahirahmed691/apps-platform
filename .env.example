# ============================================================
# Root secrets — the SINGLE SOURCE OF TRUTH for account-level
# credentials shared across every app in this monorepo.
#
# Copy this file to `.env` (gitignored) and fill in the values ONCE.
# Everything an individual app needs is DERIVED from these by
# `scripts/fill-env.js` — you never hand-edit an app's .env.local.
#
# These four cannot be auto-generated: they are account credentials.
# Everything else (per-app Supabase keys, Stripe price/webhook secrets)
# is fetched or provisioned automatically.
# ============================================================

# Stripe: secret key for your account (test or live mode).
# Dashboard > Developers > API keys.
STRIPE_SECRET_KEY=

# Anthropic: API key for generation.
# console.anthropic.com > API keys.
ANTHROPIC_API_KEY=

# OpenAI: API key for Whisper voice transcription (optional but recommended for voice-first UX).
# platform.openai.com/api-keys
OPENAI_API_KEY=

# Supabase: personal access token for the management API / CLI.
# supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Supabase: organization ID new projects are created under.
# `supabase orgs list` (after SUPABASE_ACCESS_TOKEN is set).
SUPABASE_ORG_ID=

# Vercel: optional token for non-interactive CLI (env sync, deploy).
# vercel.com/account/tokens
VERCEL_TOKEN=

# Public site URL for auth redirects, Stripe webhooks, and metadata.
# Ceevie production: https://www.ceevie.co.uk
NEXT_PUBLIC_SITE_URL=

# Google OAuth (optional — used by scripts/setup-google-auth.js).
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
# Authorized redirect URI: https://<project-ref>.supabase.co/auth/v1/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn OAuth (optional — used by scripts/setup-linkedin-auth.js).
# developer.linkedin.com → create app → enable:
#   - Sign In with LinkedIn using OpenID Connect
#   - Verified on LinkedIn (for profile URL via /identityMe)
# Authorized redirect URI: https://<project-ref>.supabase.co/auth/v1/callback
# Optional API version for /identityMe (default in app: 202510.03)
# LINKEDIN_API_VERSION=202510.03
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
